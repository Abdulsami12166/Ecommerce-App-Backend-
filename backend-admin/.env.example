# Copy from backend/.env and add separate values for admin
PORT=5001
NODE_ENV=development

# Same MongoDB
MONGO_URI=your_mongo_uri_here

# Admin JWT secret (recommended separate)
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
ADMIN_JWT_EXPIRES_IN=7d
ADMIN_JWT_REFRESH_SECRET=your_admin_refresh_secret_here
ADMIN_JWT_REFRESH_EXPIRES_IN=30d

# Reuse image provider keys from backend/.env
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend url for CORS
CLIENT_URL=

