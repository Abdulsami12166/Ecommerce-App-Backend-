# Ecommerce backend environment variables
# Copy this file to .env and fill in real values.

# Database
MONGO_URI=

# Server / CORS
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:8081

# JWT
JWT_SECRET=replace_with_user_jwt_secret
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=replace_with_admin_jwt_secret

# App branding
APP_NAME=Ecommerce

# Email / OTP delivery
# Primary: Resend
RESEND_API_KEY=
RESEND_FROM=
RESEND_FROM_NAME=Ecommerce

# Shared sender aliases used by fallback code paths
EMAIL_FROM=
SMTP_FROM=
FROM_EMAIL=

# SMTP fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_USER=
EMAIL_PASS=

# Media services
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin seed helper
ADMIN_SEED_NAME=Primary Admin
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_PHONE=
