# =====================
# Ecommerce Backend environment variables
# Copy this file to .env and fill in real values.
# =====================

# ── Database ──────────────────────────────────────────
MONGO_URI=

# ── Server / CORS ──────────────────────────────────────
NODE_ENV=development
CLIENT_URL=http://localhost:8081
PORT=5000

# ── JWT (customer sessions) ───────────────────────────
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ── Admin JWT (admin dashboard) ──────────────────────
ADMIN_JWT_SECRET=your_admin_jwt_secret_key_here

# ── App branding (used in OTP / reset-code emails) ────
APP_NAME=ShopVerse

# ── Email / OTP delivery ───────────────────────────────
# Preferred: Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Optional SMTP fallback (used when RESEND_API_KEY is absent)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Cloudinary (image uploads) ─────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── ImageKit (alternative image hosting) ───────────────
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# ── Razorpay (payments) ───────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
